#: data/org.gnome.Chess.desktop.in:2 data/chess-window.ui:52
#: src/gnome-chess.vala:1209 src/gnome-chess.vala:1538
msgid "Chess"
msgstr "Shaxmat"

#: data/org.gnome.Chess.desktop.in:3
msgid "Chess Game"
msgstr "Shaxmat oʻyini"

#: data/org.gnome.Chess.desktop.in:4 data/org.gnome.Chess.metainfo.xml.in:8
msgid "Play the classic two-player board game of chess"
msgstr "Shaxmatning klassik ikki oʻyinchili stol oʻyinini oʻynang"

#. Translators: Search terms to find this application. Do NOT translate or
#. localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.Chess.desktop.in:6
msgid "game;strategy;"
msgstr "oʻyin;strategiya;"

#: data/org.gnome.Chess.gschema.xml:38
msgid "The width of the window"
msgstr "Deraza kengligi"

#: data/org.gnome.Chess.gschema.xml:39
msgid "The width of the main window in pixels."
msgstr "Asosiy oynaning piksellardagi kengligi."

#: data/org.gnome.Chess.gschema.xml:43
msgid "The height of the window"
msgstr "Deraza kengligi va balandligi"

#: data/org.gnome.Chess.gschema.xml:44
msgid "The height of the main window in pixels."
msgstr "Asosiy oynaning piksellardagi balandligi."

#: data/org.gnome.Chess.gschema.xml:48 data/org.gnome.Chess.gschema.xml:49
msgid "A flag to enable maximized mode"
msgstr "Kattalashtirilgan rejimni yoqish uchun bayroq"

#: data/org.gnome.Chess.gschema.xml:53 data/org.gnome.Chess.gschema.xml:54
msgid "The piece theme to use"
msgstr "Foydalanish uchun parcha mavzusi"

#: data/org.gnome.Chess.gschema.xml:58 data/org.gnome.Chess.gschema.xml:59
msgid "A flag to enable board numbering"
msgstr "Doska raqamlashni yoqish uchun bayroq"

#: data/org.gnome.Chess.gschema.xml:63 data/org.gnome.Chess.gschema.xml:64
msgid "The directory to open the save game dialog in"
msgstr "Oʻyinni saqlash dialog oynasini ochish uchun katalog"

#: data/org.gnome.Chess.gschema.xml:68 data/org.gnome.Chess.gschema.xml:69
msgid "The directory to open the load game dialog in"
msgstr "Oʻyinni yuklash dialog oynasini ochish uchun katalog"

#: data/org.gnome.Chess.gschema.xml:73 data/org.gnome.Chess.gschema.xml:74
msgid "The format to display moves in"
msgstr "Koʻrsatish formati oʻtadi"

#: data/org.gnome.Chess.gschema.xml:78 data/org.gnome.Chess.gschema.xml:79
msgid "The side of the board that is in the foreground"
msgstr "Kengashning old tomonida joylashgan tomoni"

#: data/org.gnome.Chess.gschema.xml:83 data/org.gnome.Chess.gschema.xml:84
msgid "The duration of a game in seconds (0 for no limit)"
msgstr "Oʻyinning soniyalarda davomiyligi (cheklovsiz 0)"

#: data/org.gnome.Chess.gschema.xml:88 data/org.gnome.Chess.gschema.xml:89
msgid "The type of clock (simple/fischer/bronstein)"
msgstr "Soat turi (oddiy/fischer/bronshteyn)"

#: data/org.gnome.Chess.gschema.xml:93 data/org.gnome.Chess.gschema.xml:94
msgid "The timer increment set corresponding to clock type (1 second minimum)"
msgstr "Soat turiga mos keladigan taymer oʻsishi (minimal 1 soniya)"

#: data/org.gnome.Chess.gschema.xml:98 data/org.gnome.Chess.gschema.xml:99
msgid "The board side to play as"
msgstr "Qaysi tomonda oʻynash"

#: data/org.gnome.Chess.gschema.xml:103
msgid "The last side the player played as"
msgstr "Oʻyinchi oxirgi tomon sifatida oʻynadi"

#: data/org.gnome.Chess.gschema.xml:104
msgid ""
"This is needed when play-as is set to alternate. This should only be set to "
"black or white."
msgstr ""
"Bu oʻynash-as muqobil qilib sozlanganda kerak boʻladi. Bu faqat qora yoki oq"
" rangga oʻrnatilishi kerak."

#: data/org.gnome.Chess.gschema.xml:108
msgid "The opponent player"
msgstr "Raqib futbolchisi"

#: data/org.gnome.Chess.gschema.xml:109
msgid ""
"Can be 'human' (play against another human player), '' (use the first "
"available chess engine) or the name of a specific engine to play against"
msgstr ""
"\"Inson\" (boshqa inson oʻyinchisiga qarshi oʻynash), \"\" (birinchi mavjud "
"shaxmat dvigatelidan foydalaning) yoki qarshi oʻynash uchun ma'lum bir "
"dvigatel nomi boʻlishi mumkin."

#: data/org.gnome.Chess.gschema.xml:113 data/org.gnome.Chess.gschema.xml:114
msgid "Difficulty of the opponent chess engine"
msgstr "Raqibning shaxmat dvigatelining qiyinligi"

#: data/org.gnome.Chess.metainfo.xml.in:7
msgid "GNOME Chess"
msgstr "GNOME shoxmot"

#: data/org.gnome.Chess.metainfo.xml.in:10
msgid ""
"GNOME Chess is a simple chess game. You can play against your computer at "
"three different difficulty levels, or against a friend at your computer."
msgstr ""
"GNOME shaxmat - bu oddiy shaxmat oʻyini. Siz kompyuteringizga uch xil "
"qiyinchilik darajasida yoki kompyuteringizda doʻstingizga qarshi "
"oʻynashingiz mumkin."

#: data/org.gnome.Chess.metainfo.xml.in:14
msgid ""
"Computer chess enthusiasts will appreciate GNOME Chess’s compatibility with "
"nearly all modern computer chess engines, and its ability to detect several "
"popular engines automatically if installed."
msgstr ""
"Kompyuter shaxmat ixlosmandlari GNOME Chess-ning deyarli barcha zamonaviy "
"kompyuter shaxmat dvigatellari bilan mosligini va oʻrnatilgan boʻlsa, bir "
"nechta mashhur dvigatellarni avtomatik ravishda aniqlash qobiliyatini "
"qadrlashadi."

