#, rust-format
msgid "The URI parameter “role” must be “follower” or “leader” (was: “{}”)"
msgstr "URI \"rol\" parametri \"kuzatuvchi\" yoki \"yetakchi\" boʻlishi kerak (edi: \"{}\")"

