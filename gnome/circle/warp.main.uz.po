#: src/util/error.rs:194
msgid "An error occurred"
msgstr "Xatolik yuz berdi"

#: src/util/error.rs:222 src/util/error.rs:353
msgid "Corrupt or unexpected message received"
msgstr "Buzilgan yoki kutilmagan xabar olindi"

#: src/util/error.rs:228
msgid ""
"The rendezvous server will not allow further connections for this code. A "
"new code needs to be generated."
msgstr ""
"Uchrashuv serveri ushbu kod uchun qoʻshimcha ulanishlarga ruxsat bermaydi. "
"Yangi kodni generatsiya qilish kerak."

#: src/util/error.rs:232
msgid ""
"The rendezvous server removed the code due to inactivity. A new code needs "
"to be generated."
msgstr ""
"Uchrashuvlar serveri faolsizlik tufayli kodni oʻchirib tashladi. Yangi kod "
"yaratish zarur."

#: src/util/error.rs:236
#, rust-format
msgid "The rendezvous server responded with an unknown message: {}"
msgstr "Uchrashuv serveri noma’lum xabar bilan javob berdi: {}"

#: src/util/error.rs:247
msgid ""
"Error connecting to the rendezvous server.\n"
"You have entered a custom rendezvous server URL in preferences. Please verify the URL is correct and the server is working."
msgstr ""
"Uchrashuv serveriga ulanishda xatolik yuz berdi.\n"
"Sozlamalarda maxsus uchrashuv serveri URL manzilini kiritdingiz. URL toʻgʻriligini va server ishlayotganini tekshiring."

#: src/util/error.rs:251
msgid ""
"Error connecting to the rendezvous server.\n"
"Please try again later / verify you are connected to the internet."
msgstr ""
"Uchrashuv serveriga ulanishda xatolik yuz berdi.\n"
"Keyinroq qayta urining / internetga ulanganingizni tekshiring."

#: src/util/error.rs:256
msgid ""
"Encryption key confirmation failed. If you or your peer didn't mistype the "
"code, this is a sign of an attacker guessing passwords. Please try again "
"some time later."
msgstr ""
"Shifrlash kaliti tasdiqlanmadi. Agar siz yoki sherigingiz kodni notoʻgʻri "
"yozmagan boʻlsa, bu hujumchi parollarni taxmin qilayotganining belgisidir. "
"Birozdan keyin qayta urining."

#: src/util/error.rs:258
msgid "Cannot decrypt a received message"
msgstr "Qabul qilingan xabarni shifrdan ochib boʻlmadi"

#: src/util/error.rs:259 src/util/error.rs:364 src/util/error.rs:374
msgid "An unknown error occurred"
msgstr "Nomaʼlum muammo yuzaga keldi"

#. Translators: magic-wormhole codes usually look like n-word-word... where n
#. MUST be an arabic number (unlimited digits). The first '-' is mandatory.
#. This error occurs when an empty code was entered.
#: src/util/error.rs:266
msgid "The specified code must not be empty"
msgstr "Koʻrsatilgan kod boʻsh boʻlmasligi kerak"

#. Translators: magic-wormhole codes usually look like n-word-word... where n
#. MUST be an arabic number (unlimited digits). The first '-' is mandatory.
#. This error occurs when a code was entered that does not contain any '-'.
#: src/util/error.rs:268
msgid "The code must contain at least one “-”"
msgstr "Kodda kamida bitta “-” boʻlishi kerak"

#. Translators: magic-wormhole codes usually look like n-word-word... where n
#. MUST be an arabic number (unlimited digits). This error occurs when a code
#. was entered that does not contain a number before the '-'.
#: src/util/error.rs:270
msgid "The first segment of a code must be a number"
msgstr "Kodning birinchi boʻlagi albatta raqam boʻlishi shart"

#: src/util/error.rs:274
#, rust-format
msgid "Code too weak. It can be guessed with an average of {} try."
msgid_plural "Code too weak. It can be guessed with an average of {} tries."
msgstr[0] ""
"Kod juda zaif. Buni o‘rtacha {} ta urinish bilan taxmin qilish mumkin."

#: src/util/error.rs:282
#, rust-format
msgid ""
"Code too short. The text after the “-” must be at least {} character long."
msgid_plural ""
"Code too short. The text after the “-” must be at least {} characters long."
msgstr[0] ""
"Kod juda qisqa. “-” belgisidan keyingi matn kamida {} ta belgidan iborat "
"bo‘lishi kerak."

#: src/util/error.rs:289
msgid "Code too weak"
msgstr "Kod juda zaif"

#: src/util/error.rs:296
msgid "File / Directory not found"
msgstr "Fayl / Jild topilmadi"

#: src/util/error.rs:297
msgid "Permission denied"
msgstr "Ruxsat berilmadi"

#: src/util/error.rs:305
msgid "Canceled"
msgstr "Bekor qilingan"

#: src/util/error.rs:307
msgid "Portal service response: Permission denied"
msgstr "Portal xizmati javobi: Ruxsat berilmadi"

#: src/util/error.rs:310
#, rust-format
msgid "The portal service has failed: {}"
msgstr "Portal xizmati ishlamay qoldi: {}"

#: src/util/error.rs:313
#, rust-format
msgid "Error communicating with the portal service via zbus: {}"
msgstr ""
"Zbus orqali portal xizmati bilan aloqa oʻrnatishda xatolik yuz berdi: {}"

#: src/util/error.rs:316 src/util/error.rs:317
#, rust-format
msgid "Portal error: {}"
msgstr "Portalda xatolik: {}"

#: src/util/error.rs:328
msgid "Transfer was not acknowledged by peer"
msgstr "Uzatish sherigingiz tomonidan tasdiqlanmadi"

#: src/util/error.rs:330
msgid "The received file is corrupted"
msgstr "Qabul qilingan fayl buzilgan"

#: src/util/error.rs:336
#, rust-format
msgid ""
"The file contained a different amount of bytes than advertised! Sent {} "
"bytes, but should have been {}"
msgstr ""
"Fayl e’lon qilingan hajmdan farqli miqdordagi baytlarni oʻz ichiga oldi! {} "
"bayt yuborildi, ammo aslida {} bayt boʻlishi kerak edi"

#: src/util/error.rs:341
msgid "The other side has cancelled the transfer"
msgstr "Narigi tomon uzatishni bekor qildi"

#: src/util/error.rs:343
msgid "The other side has rejected the transfer"
msgstr "Narigi tomon uzatishni rad etdi"

#: src/util/error.rs:345
#, rust-format
msgid "Something went wrong on the other side: {}"
msgstr "Boshqa tomonda xatolik yuz berdi: {}"

#: src/util/error.rs:360
msgid "Error while establishing file transfer connection"
msgstr "Fayl uzatish aloqasini oʻrnatishda xatolik yuz berdi"

#: src/util/error.rs:362
