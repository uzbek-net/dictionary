#: data/app.drey.Warp.desktop.in.in:3 data/app.drey.Warp.metainfo.xml.in.in:5
#: src/ui/welcome_dialog.ui:31
msgid "Fast and secure file transfer"
msgstr "Fayllarni tez va xavfsiz uzatish"

#: data/app.drey.Warp.desktop.in.in:8
msgid "Gnome;GTK;Wormhole;Magic-Wormhole;"
msgstr "Gnome;GTK;Wormhole;Magic-Wormhole;"

#: data/app.drey.Warp.metainfo.xml.in.in:61
msgid ""
"Warp allows you to securely send files to each other via the internet or "
"local network by exchanging a word-based code."
msgstr ""
"Warp soʻzga asoslangan maxsus kod orqali fayllarni internet yoki mahalliy "
"tarmoq boʻylab bir-biringizga xavfsiz yuborish imkonini beradi."

#: data/app.drey.Warp.metainfo.xml.in.in:65
msgid ""
"The best transfer method will be determined using the “Magic Wormhole” "
"protocol which includes local network transfer if possible."
msgstr ""
"Eng yaxshi uzatish usuli iloji boricha mahalliy tarmoqni uzatishni oʻz "
"ichiga olgan “Magic Wormhole” protokoli yordamida aniqlanadi."

#: data/app.drey.Warp.metainfo.xml.in.in:69
msgid "Features"
msgstr "Funksiyalar"

#: data/app.drey.Warp.metainfo.xml.in.in:71
msgid "Send files between multiple devices"
msgstr "Fayllarni bir nechta qurilmalar orasida yuborish"

#: data/app.drey.Warp.metainfo.xml.in.in:72
msgid "Every file transfer is encrypted"
msgstr "Har bir fayl uzatilishi shifrlangan"

#: data/app.drey.Warp.metainfo.xml.in.in:73
msgid "Directly transfer files on the local network if possible"
msgstr "Iloji boʻlsa, fayllarni mahalliy tarmoqqa bevosita uzatish"

#: data/app.drey.Warp.metainfo.xml.in.in:74
msgid "An internet connection is required"
msgstr "Internetga ulanish talab etiladi"

#: data/app.drey.Warp.metainfo.xml.in.in:75
msgid "QR Code support"
msgstr "QR kod qoʻllab-quvvatlash"

#: data/app.drey.Warp.metainfo.xml.in.in:76
#, fuzzy
msgid ""
"Compatibility with the Magic Wormhole command line client and all other "
"compatible apps"
msgstr ""
"Magic Wormhole buyruq qatori dasturi va boshqa barcha mos keluvchi ilovalar "
"bilan mosligi"

