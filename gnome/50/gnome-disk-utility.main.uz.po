#: src/disks/gdu-ata-smart-dialog.c:294
msgid "Number of cycles into landing zone position"
msgstr "Qoʻnish zonasi holatiga aylanishlar soni"

#. Translators: SMART attribute, see
#. http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#: src/disks/gdu-ata-smart-dialog.c:301 src/disks/gdu-ata-smart-dialog.c:520
#: src/disks/ui/gdu-ata-smart-dialog.ui:80
msgid "Temperature"
msgstr "Harorat birligi"

#: src/disks/gdu-ata-smart-dialog.c:302
msgid "Current internal temperature of the drive"
msgstr "Drayvning joriy ichki harorati"

#. Translators: SMART attribute, see
#. http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#: src/disks/gdu-ata-smart-dialog.c:309
msgid "Hardware ECC Recovered"
msgstr "ECC apparati tiklandi"

#: src/disks/gdu-ata-smart-dialog.c:310
msgid "Number of ECC on-the-fly errors"
msgstr "ECC on-the-fly xatolar soni"

#. Translators: SMART attribute, see
#. http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#: src/disks/gdu-ata-smart-dialog.c:317
msgid "Reallocation Count"
msgstr "Qayta taqsimlash soni"

#: src/disks/gdu-ata-smart-dialog.c:318
msgid ""
"Number of remapping operations. The raw value of this attribute shows the "
"total number of (successful and unsuccessful) attempts to transfer data from"
" reallocated sectors to a spare area"
msgstr ""
"Remapping operatsiyalari soni. Ushbu atributning xom qiymati qayta "
"taqsimlangan sektorlardan maʼlumotlarni zaxira hududga oʻtkazishga "
"(muvaffaqiyatli va muvaffaqiyatsiz) urinishlarning umumiy sonini koʻrsatadi"

#. Translators: SMART attribute, see
#. http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#: src/disks/gdu-ata-smart-dialog.c:328
msgid "Current Pending Sector Count"
msgstr "Joriy kutilayotgan sektorlar soni"

#: src/disks/gdu-ata-smart-dialog.c:329
msgid ""
"Number of sectors waiting to be remapped. If the sector waiting to be "
"remapped is subsequently written or read successfully, this value is "
"decreased and the sector is not remapped. Read errors on the sector will not"
" remap the sector, it will only be remapped on a failed write attempt"
msgstr ""
"Qayta koʻrsatilishi kutilayotgan sektorlar soni. Agar qayta xaritalashni "
"kutayotgan sektor keyinchalik yozilsa yoki muvaffaqiyatli oʻqilsa, bu qiymat"
" kamayadi va sektor qayta koʻrsatilmaydi. Sektordagi oʻqish xatolari "
"sektorni qayta koʻrsatmaydi, faqat muvaffaqiyatsiz yozish urinishida qayta "
"koʻrsatiladi"

#. Translators: SMART attribute, see
#. http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#: src/disks/gdu-ata-smart-dialog.c:340
msgid "Uncorrectable Sector Count"
msgstr "Tuzatib boʻlmaydigan sektorlar soni"

#: src/disks/gdu-ata-smart-dialog.c:341
msgid ""
"The total number of uncorrectable errors when reading/writing a sector. A "
"rise in the value of this attribute indicates defects of the disk surface "
"and/or problems in the mechanical subsystem"
msgstr ""
"Sektorni oʻqish/yozishda tuzatib boʻlmaydigan xatolarning umumiy soni. Ushbu"
" atribut qiymatining oshishi disk yuzasidagi nuqsonlarni va/yoki mexanik "
"quyi tizimdagi muammolarni koʻrsatadi"

#. Translators: SMART attribute, see
#. http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#: src/disks/gdu-ata-smart-dialog.c:350
msgid "UDMA CRC Error Rate"
msgstr "UDMA CRC xatolik darajasi"

#: src/disks/gdu-ata-smart-dialog.c:351
msgid "Number of CRC errors during UDMA mode"
msgstr "UDMA rejimida CRC xatolar soni"

#. Translators: SMART attribute, see
#. http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#: src/disks/gdu-ata-smart-dialog.c:358
msgid "Write Error Rate"
msgstr "Yozish xatosi darajasi"

#: src/disks/gdu-ata-smart-dialog.c:359
msgid ""
"Number of errors while writing to disk (or) multi-zone error rate (or) "
"flying-height"
msgstr ""
"Diskka yozish paytida xatolar soni (yoki) koʻp zonali xatolik darajasi "
"(yoki) uchish balandligi"

#. Translators: SMART attribute, see
#. http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#: src/disks/gdu-ata-smart-dialog.c:366
msgid "Soft Read Error Rate"
msgstr "Yumshoq oʻqish xatosi darajasi"

#: src/disks/gdu-ata-smart-dialog.c:367
msgid "Number of off-track errors"
msgstr "Yoʻldan tashqari xatolar soni"

#. Translators: SMART attribute, see
#. http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#: src/disks/gdu-ata-smart-dialog.c:374
msgid "Data Address Mark Errors"
msgstr "Ma'lumotlar manzilini belgilash xatolar"

#: src/disks/gdu-ata-smart-dialog.c:375
msgid "Number of Data Address Mark (DAM) errors (or) vendor-specific"
msgstr "Ma'lumotlar manzili belgisi (DAM) xatolar soni (yoki) sotuvchiga xos"

#. Translators: SMART attribute, see
#. http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#: src/disks/gdu-ata-smart-dialog.c:382
msgid "Run Out Cancel"
msgstr "Tugadi Bekor qilish"

#: src/disks/gdu-ata-smart-dialog.c:383
msgid "Number of ECC errors"
msgstr "ECC xatolar soni"

#. Translators: SMART attribute, see
#. http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#: src/disks/gdu-ata-smart-dialog.c:390
msgid "Soft ECC correction"
msgstr "Yumshoq ECC tuzatish"

#: src/disks/gdu-ata-smart-dialog.c:391
msgid "Number of errors corrected by software ECC"
msgstr "ECC dasturiy ta'minoti tomonidan tuzatilgan xatolar soni"

#. Translators: SMART attribute, see
#. http://smartmontools.sourceforge.net/doc.html
#. * or the next string for a longer explanation.
#: src/disks/gdu-ata-smart-dialog.c:398
msgid "Thermal Asperity Rate"
