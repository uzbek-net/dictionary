msgstr[0] "Hujayra %d qatorni qamrab oladi"
msgstr[1] "Hujayra %d ta qatorni qamrab oladi"

#. Translators: this represents the number of columns in a table.
#: src/orca/messages.py:2455
#, python-format
msgid " %d column"
msgid_plural " %d columns"
msgstr[0] " %d ustun"
msgstr[1] " %d ta ustun"

#. Translators: The cell here refers to a cell within a table within a
#. document. We need to announce when the cell occupies or "spans" more
#. than a single row and/or column.
#: src/orca/messages.py:2460
#, python-format
msgid "Cell spans %d column"
msgid_plural "Cell spans %d columns"
msgstr[0] "Hujayra %d ustunini qamrab oladi"
msgstr[1] "Hujayra %d ta ustundan iborat"

#. Translators: This message describes the number of characters in a string.
#: src/orca/messages.py:2474
#, python-format
