msgid_plural "(%d dialogs)"
msgstr[0] "(%d dialog oynasi)"
msgstr[1] "(%d ta dialog)"

#. Translators: This message informs the user how many unfocused alert and
#. dialog windows a newly (re)focused application has. It is added at the
#. end of a spoken message containing the app which just claimed focus.
#: src/orca/messages.py:2517
#, python-format
msgid "%d unfocused dialog"
msgid_plural "%d unfocused dialogs"
msgstr[0] "%d fokuslanmagan muloqot oynasi"
msgstr[1] "%d ta markazlashtirilmagan dialoglar"

#. Translators: This is the size of a file in bytes
#: src/orca/messages.py:2524
#, python-format
msgid "%d byte"
msgid_plural "%d bytes"
msgstr[0] "%d bayt"
msgstr[1] "%d bayt"

#. Translators: This message informs the user hoq many files were found as
#. a result of a search.
#: src/orca/messages.py:2532
#, python-format
msgid "%d file found"
msgid_plural "%d files found"
msgstr[0] "%d fayl"
msgstr[1] "%d ta fayl topildi"

