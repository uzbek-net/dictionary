#. identify important part of webpage like banners, main context, search etc.
#: src/orca/messages.py:2572
#, python-format
msgid "%d landmark"
msgid_plural "%d landmarks"
msgstr[0] "%d belgi"
msgstr[1] "%d ta diqqatga sazovor joylar"

