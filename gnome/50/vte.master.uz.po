#: src/vte.cc:8497
msgid "WARNING"
msgstr "OGOHLANTIRISH"

#: src/vte.cc:8499
msgid "GnuTLS not enabled; data will be written to disk unencrypted!"
msgstr ""
"GnuTLS faollashtirilmagan; ma'lumotlar diskka shifrlanmagan holda yoziladi!"

# Pipe muammosi.
# "nonblocking mode" nimaligini ko'rish kerak
#: src/spawn.cc:133
#, c-format
msgid "Failed to set pipe nonblocking: %s"
msgstr "Payp blokirovka qilmaslikni oʻrnatib boʻlmadi: %s"

# "poll" - so'rovnoma? Yoki boshqa ma'noda, jamiyatda so'rash kerak
#: src/spawn.cc:178
#, c-format
msgid "poll error: %s"
msgstr "poll xatosi: %s"

# Buning ma'nosi bunday:   Amaliyot bo'lishi kerak edi, lekin ko'p vaqt o'tib
# ketdi. Va amaliyot bo'lmadi. Shuni nimadir deb yozish kerak 😂😂
#: src/spawn.cc:185
msgid "Operation timed out"
msgstr "Operatsiya vaqti tugadi"

#: src/spawn.cc:195
msgid "Operation was cancelled"
msgstr "Amaliyot bekor qilindi"

# Child pipe   :think
#: src/spawn.cc:213
#, c-format
msgid "Failed to read from child pipe (%s)"
msgstr "Bola paypdan (%s) oʻqib boʻlmadi"

#: src/spawn.cc:664
#, c-format
msgid "Failed to change to directory “%s”: %s"
msgstr "“%s” katalogiga oʻzgartirib boʻlmadi: %s"

# child process, shunchaki process emas
#: src/spawn.cc:733
#, c-format
msgid "Failed to execute child process “%s”: "
msgstr "“%s” bola jarayonini bajarib boʻlmadi: "
